# Audio
CONFIG_XIAOMI_SPK_ID=y

# Camera
CONFIG_MSMB_CAMERA_LEGACY=y

# Platform
CONFIG_MACH_XIAOMI_PLATINA=y

# Touchscreen
CONFIG_TOUCHSCREEN_SYNAPTICS_TCM_D2T=y
CONFIG_TOUCHSCREEN_SYNAPTICS_TCM_I2C_D2T=y
CONFIG_TOUCHSCREEN_SYNAPTICS_TCM_CORE=y
CONFIG_TOUCHSCREEN_SYNAPTICS_TCM_TOUCH=y
CONFIG_TOUCHSCREEN_SYNAPTICS_TCM_DEVICE=y
CONFIG_TOUCHSCREEN_SYNAPTICS_TCM_TESTING=y
CONFIG_TOUCHSCREEN_SYNAPTICS_TCM_REFLASH=y
CONFIG_TOUCHSCREEN_SYNAPTICS_TCM_RECOVERY=y
CONFIG_TOUCHSCREEN_SYNAPTICS_TCM_ZEROFLASH=y
CONFIG_TOUCHSCREEN_SYNAPTICS_TCM_DIAGNOSTICS=y
CONFIG_TOUCHSCREEN_NVT_D2T=y
CONFIG_TOUCHSCREEN_FOCAL_FT8719_D2T=y

# PROCESS_RECLAIM
CONFIG_PROCESS_RECLAIM=n
CONFIG_QCOM_KGSL_PROCESS_RECLAIM=n

# I/O Scheduler 
CONFIG_IOSCHED_CFQ=n
CONFIG_IOSCHED_DEADLINE=n
CONFIG_IOSCHED_NOOP=n
CONFIG_MQ_IOSCHED_SSG=y
CONFIG_MQ_IOSCHED_SSG_CGROUP=y

# Skip kernel's sys_sync
CONFIG_SUSPEND_SKIP_SYNC=y

# ZRAM
CONFIG_ZRAM_SIZE_OVERRIDE=2

# BALANCE_ANON_FILE_RECLAIM
CONFIG_BALANCE_ANON_FILE_RECLAIM=y

# FRAME WARN
CONFIG_FRAME_WARN=0

# AUDIT
CONFIG_AUDIT=n

# Security
CONFIG_SECURITY_SMACK=n
CONFIG_SECURITY_NETWORK=y

# Emulate Privileged Access Never using TTBR0_EL1 switching
CONFIG_ARM64_SW_TTBR0_PAN=n

# DEBUG
CONFIG_DEBUG_ALIGN_RODATA=n
CONFIG_IPC_LOGGING=n
CONFIG_DEBUG_INFO=n
CONFIG_PANIC_TIMEOUT=-1
CONFIG_SCHEDSTATS=n
CONFIG_BUG_ON_DATA_CORRUPTION=n
CONFIG_STACKTRACE=y

# CPU
CONFIG_CPU_FREQ_TIMES=n

# UNMAP_KERNEL_AT_EL0
CONFIG_UNMAP_KERNEL_AT_EL0=n

# EL2 vector hardening
CONFIG_HARDEN_EL2_VECTORS=n

# Harden slab freelist metadata
CONFIG_SLAB_FREELIST_HARDENED=y

# Arch
# CONFIG_ARCH_SDM630 is not set
CONFIG_ARCH_SDM660=y

# ARMv8.1 architectural features
CONFIG_ARM64_HW_AFDBM=n
CONFIG_ARM64_PAN=n
CONFIG_ARM64_LSE_ATOMICS=n
CONFIG_ARM64_VHE=n

# ARMv8.2 architectural features
CONFIG_ARM64_UAO=n
CONFIG_ARM64_PMEM=n
CONFIG_ARM64_RAS_EXTN=n
CONFIG_ARM64_SVE=n
CONFIG_RANDOMIZE_BASE=y
CONFIG_RANDOMIZE_MODULE_REGION_FULL=n

# Spectre-BHB mitigation
CONFIG_MITIGATE_SPECTRE_BRANCH_HISTORY=n

# 16-bit UID calls
CONFIG_UID16=n

# Hid-playstation driver/rumble
CONFIG_HID_PLAYSTATION=y
CONFIG_PLAYSTATION_FF=y

# PROFILING
CONFIG_PROFILING=n
CONFIG_PERF_EVENTS=y

# Selinx
CONFIG_SECURITY_SELINUX_AVC_STATS=n

# TRACE_GPU_MEM
CONFIG_TRACE_GPU_MEM=n

# Uname
CONFIG_UNAME_OVERRIDE=y
CONFIG_UNAME_OVERRIDE_TARGET="com.google.android.gms"
CONFIG_UNAME_OVERRIDE_STRING="4.19.325-perf+"

# DEVREQ
CONFIG_DEVFREQ_BOOST=y
CONFIG_DEVFREQ_INPUT_BOOST_DURATION_MS=32
CONFIG_DEVFREQ_WAKE_BOOST_DURATION_MS=0
CONFIG_DEVFREQ_MSM_CPUBW_BOOST_FREQ=2929

# BATTERY SAVER ON/OFF
CONFIG_BATTERY_SAVER=y

# DEBUGFS
CONFIG_REGMAP_ALLOW_WRITE_DEBUGFS=n
CONFIG_USB_GADGET_DEBUG_FS=n